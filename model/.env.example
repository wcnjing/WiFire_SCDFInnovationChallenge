# Copy this file to .env and fill in your own keys.
# .env is gitignored.

# LTA DataMall — register at https://datamall.lta.gov.sg/content/datamall/en/request-for-api.html
LTA_ACCOUNT_KEY=your_lta_key_here

# OneMap — register at https://www.onemap.gov.sg/apidocs/register
ONEMAP_EMAIL=your_email_here
ONEMAP_PASSWORD=your_password_here

# NEA endpoints used here do not require a key.

# Optional: TLS workarounds for corporate networks doing MITM interception.
# Set SSL_VERIFY=false ONLY if you cannot import your corporate root CA.
# Prefer SSL_CA_BUNDLE pointing at a cacert.pem that includes your corp CA.
# SSL_VERIFY=true
# SSL_CA_BUNDLE=/path/to/cacert.pem
